{
  "name": "@expiry-label/mobile-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5174",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 5174",
    "native:sync": "npm run build && cap sync",
    "native:android": "npm run native:sync && cap open android",
    "native:ios": "npm run native:sync && cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "6.2.1",
    "@capacitor/core": "6.2.1",
    "@capacitor/ios": "6.2.1",
    "@vitejs/plugin-react": "^4.3.4",
    "antd-mobile": "^5.38.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "6.2.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
